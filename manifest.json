{
  "manifest_version": 3,
  "name": "FB Reels Cleaner",
  "version": "1.0.0",
  "description": "Delete all your Facebook Reels at once or one by one. Free tool by Stacknix.dev",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
